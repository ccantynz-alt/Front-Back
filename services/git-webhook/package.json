{
  "name": "@back-to-the-future/git-webhook",
  "type": "module",
  "version": "0.0.1",
  "private": true,
  "exports": {
    ".": "./src/index.ts",
    "./schemas": "./src/schemas.ts",
    "./transport": "./src/transport.ts"
  },
  "scripts": {
    "start": "bun run src/server.ts",
    "dev": "bun run --hot src/server.ts",
    "build": "bun build src/server.ts --outdir dist --target bun",
    "test": "bun test",
    "check": "tsc --noEmit",
    "lint": "biome check .",
    "format": "biome format . --write"
  },
  "dependencies": {
    "hono": "^4.7.11",
    "zod": "^4"
  },
  "devDependencies": {
    "typescript": "^6",
    "@types/bun": "^1.2.0"
  }
}
