{
  "name": "@back-to-the-future/tunnel",
  "type": "module",
  "version": "0.0.1",
  "private": true,
  "main": "./src/origin.ts",
  "exports": {
    "./origin": "./src/origin.ts",
    "./edge": "./src/edge.ts",
    "./frame": "./src/frame.ts",
    "./auth": "./src/auth.ts"
  },
  "scripts": {
    "start:origin": "bun run src/origin.ts",
    "start:edge": "bun run src/edge.ts",
    "dev:origin": "bun run --hot src/origin.ts",
    "dev:edge": "bun run --hot src/edge.ts",
    "build": "bun build src/origin.ts --outdir dist/origin --target bun && bun build src/edge.ts --outdir dist/edge --target bun",
    "test": "bun test",
    "check": "tsc --noEmit",
    "lint": "biome check .",
    "format": "biome format . --write"
  },
  "devDependencies": {
    "typescript": "^6.0.2",
    "@types/bun": "^1.2.0"
  }
}
