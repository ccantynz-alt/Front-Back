{
  "name": "@back-to-the-future/video-pipeline",
  "type": "module",
  "version": "0.0.1",
  "exports": {
    ".": "./src/index.ts",
    "./browser": "./src/browser/index.ts",
    "./server": "./src/server/index.ts",
    "./core": "./src/core/index.ts"
  },
  "scripts": {
    "start": "bun run src/server/index.ts",
    "dev": "bun run --hot src/server/index.ts",
    "build": "bun build src/server/index.ts --outdir dist --target bun",
    "test": "bun test",
    "check": "tsc --noEmit",
    "lint": "biome check .",
    "format": "biome format . --write"
  },
  "dependencies": {
    "hono": "^4.7.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "typescript": "^6.0.2",
    "@types/bun": "^1.2.0"
  }
}
