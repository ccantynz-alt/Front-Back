# ============================================================================
# Crontech Platform — Production Environment Variables
# ============================================================================
#
# Copy to .env.production and fill in your values:
#   cp .env.production.example .env.production
#
# Generate secrets with:
#   openssl rand -hex 32
#
# NEVER commit .env.production to git.
# ============================================================================

# ── Domain ─────────────────────────────────────────────────────────────
# The apex domain. Used to derive api.DOMAIN, *.DOMAIN.app, etc.
CRONTECH_DOMAIN=crontech.ai

# ── Git SHA ────────────────────────────────────────────────────────────
# Set by CI/CD at deploy time. Baked into the client bundle and exposed
# via /api/version for post-deploy smoke tests.
GIT_SHA=unknown

# ── ACME / TLS ─────────────────────────────────────────────────────────
# Email for Let's Encrypt certificate expiry notifications.
ACME_EMAIL=admin@crontech.ai

# ── Database ───────────────────────────────────────────────────────────
# Turso (primary edge SQLite — used by the API for most reads/writes)
TURSO_DATABASE_URL=libsql://your-db.turso.io
TURSO_AUTH_TOKEN=                            # Generate at turso.tech dashboard

# Neon (serverless PostgreSQL — complex queries, full Postgres power)
# Only needed if features depend on Postgres. Can be blank for Phase 1.
NEON_DATABASE_URL=

# Local PostgreSQL fallback (if running the optional postgres container)
DATABASE_URL=postgresql://crontech:CHANGE_ME_STRONG_PASSWORD@postgres:5432/crontech
POSTGRES_USER=crontech
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD  # openssl rand -hex 24

# ── Qdrant (Vector DB) ────────────────────────────────────────────────
# Internal URL — resolved via Docker DNS. No change needed.
# QDRANT_URL is set in docker-compose, not here.
QDRANT_API_KEY=                              # Optional. Set if Qdrant auth is enabled.

# ── Auth Secrets ───────────────────────────────────────────────────────
# CRITICAL: Generate unique values. Never reuse across environments.
SESSION_SECRET=CHANGE_ME                     # openssl rand -hex 32
JWT_SECRET=CHANGE_ME                         # openssl rand -hex 32

# ── WebAuthn / Passkeys ───────────────────────────────────────────────
# Derived from CRONTECH_DOMAIN in docker-compose. Override here only if
# the RP ID differs from the domain (rare).
# WEBAUTHN_RP_ID=crontech.ai
# WEBAUTHN_RP_NAME=Crontech
# WEBAUTHN_ORIGIN=https://crontech.ai

# ── Google OAuth 2.0 ──────────────────────────────────────────────────
# Create at https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Stripe (Billing) ──────────────────────────────────────────────────
# https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# ── AI ─────────────────────────────────────────────────────────────────
# Features degrade gracefully if these are blank.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ── Email ──────────────────────────────────────────────────────────────
# AlecRae MTA (primary — self-hosted mail infrastructure)
ALECRAE_API_URL=
ALECRAE_API_KEY=

# Resend (fallback — used until AlecRae MTA is live)
RESEND_API_KEY=

# Sender address for transactional emails
EMAIL_FROM=noreply@crontech.ai

# ── Redis ──────────────────────────────────────────────────────────────
# Internal URL — resolved via Docker DNS. Override only for external Redis.
# REDIS_URL=redis://redis:6379

# ── Observability (optional — enable with --profile observability) ────
# Internal OTel collector endpoint — set in docker-compose for core
# services. Override here only for external collectors.
# OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318

# Grafana admin credentials (only used with observability profile)
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=CHANGE_ME             # openssl rand -hex 16

# ── Sentinel (Competitive Intelligence) ───────────────────────────────
# Optional. Sentinel features degrade gracefully without these.
SLACK_WEBHOOK_URL=
DISCORD_WEBHOOK_URL=
GITHUB_TOKEN=                                # PAT for GitHub release monitoring

# ── Orchestrator ───────────────────────────────────────────────────────
# Internal port. No change needed unless port 9000 conflicts.
# ORCHESTRATOR_PORT=9000
