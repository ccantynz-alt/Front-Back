# ── Database ───────────────────────────────────────────────────────────
DATABASE_URL=libsql://your-database.turso.io
TURSO_AUTH_TOKEN=your-turso-auth-token

# ── AI Provider ────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-api-key

# ── WebAuthn / Passkeys ────────────────────────────────────────────────
WEBAUTHN_RP_ID=localhost
WEBAUTHN_RP_NAME=Back to the Future

# ── Neon Serverless PostgreSQL ─────────────────────────────────────────
NEON_DATABASE_URL=postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/dbname

# ── Qdrant Vector Database ────────────────────────────────────────────
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=your-qdrant-api-key

# ── OpenTelemetry ─────────────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# ── AI Models (Optional overrides) ───────────────────────────────────
AI_CLOUD_MODEL=gpt-4o
AI_EDGE_MODEL=gpt-4o-mini

# ── Public API URL (accessible from the browser) ──────────────────────
PUBLIC_API_URL=http://localhost:3001
