# ── Database ───────────────────────────────────────────────────────────
DATABASE_URL=libsql://your-database.turso.io
TURSO_AUTH_TOKEN=your-turso-auth-token

# ── AI Provider ────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-api-key

# ── WebAuthn / Passkeys ────────────────────────────────────────────────
WEBAUTHN_RP_ID=localhost
WEBAUTHN_RP_NAME=Marco Reid

# ── Neon Serverless PostgreSQL ─────────────────────────────────────────
NEON_DATABASE_URL=postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/dbname
NEON_API_KEY=your-neon-api-key

# ── Qdrant Vector Database ────────────────────────────────────────────
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=your-qdrant-api-key

# ── OpenTelemetry ─────────────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# ── AI Models (Optional overrides) ───────────────────────────────────
AI_CLOUD_MODEL=gpt-4o
AI_EDGE_MODEL=gpt-4o-mini

# ── Stripe ────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key
STRIPE_WEBHOOK_SECRET=whsec_your-stripe-webhook-secret

# ── Sentinel (Optional) ──────────────────────────────────────────────
GITHUB_TOKEN=ghp_your-github-token
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/your/webhook/url
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your/webhook/url

# ── Email (Resend) ────────────────────────────────────────────────────
RESEND_API_KEY=re_your-resend-api-key
EMAIL_FROM=noreply@marcoreid.com

# ── Inbound email (Resend) ────────────────────────────────────────────
RESEND_INBOUND_SECRET=your-resend-webhook-signing-secret
SUPPORT_EMAIL=support@marcoreid.com
SUPPORT_AUTO_SEND_THRESHOLD=85

# ── Branding & Public URLs ────────────────────────────────────────────
# Set these once you have a domain. Everything updates automatically.
SITE_NAME=Marco Reid
PUBLIC_URL=https://marcoreid.com
SALES_EMAIL=sales@marcoreid.com

# ── Vertical Subdomains ───────────────────────────────────────────────
# Each vertical product lives on its own subdomain of the root domain.
ACCOUNTING_URL=https://accounting.marcoreid.com
LEGAL_URL=https://legal.marcoreid.com
IMMIGRATION_URL=https://immigration.marcoreid.com

# ── Public API URL (accessible from the browser) ──────────────────────
PUBLIC_API_URL=https://api.marcoreid.com

# ── Vite (browser-exposed env vars - must be prefixed VITE_) ──────────
VITE_PUBLIC_URL=https://marcoreid.com
VITE_SITE_NAME=Marco Reid
VITE_SALES_EMAIL=sales@marcoreid.com
VITE_API_URL=https://api.marcoreid.com
VITE_ACCOUNTING_URL=https://accounting.marcoreid.com
