# ── Core Runtime ───────────────────────────────────────────────────────
# Port the Hono API listens on (apps/api). Defaults to 3001.
API_PORT=3001
# When "true", or any time NODE_ENV != production, runMigrations() is called
# on API boot. Leave unset in production to run migrations out-of-band.
AUTO_MIGRATE=true
# Comma-separated list of additional CORS origins to allow (beyond the built-in
# localhost + PUBLIC_URL/VITE_* defaults). Example:
#   CORS_ORIGINS=https://app.example.com,https://staging.example.com
CORS_ORIGINS=
# Injected by CI at build time. Surfaced on /api/version and /health so the UI
# can display the live commit SHA. Safe to leave unset locally.
GIT_SHA=

# ── Database (Turso / libsql) ──────────────────────────────────────────
DATABASE_URL=libsql://your-database.turso.io
DATABASE_AUTH_TOKEN=your-turso-auth-token

# ── AI Providers ───────────────────────────────────────────────────────
# Anthropic is PRIMARY when set. OpenAI becomes FALLBACK automatically.
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key
OPENAI_API_KEY=sk-your-openai-api-key
# Optional: separate key for the edge tier (falls back to OPENAI_API_KEY).
AI_EDGE_API_KEY=
# Optional model overrides for the three-tier router.
AI_CLOUD_MODEL=gpt-4o
AI_EDGE_MODEL=gpt-4o-mini

# ── WebAuthn / Passkeys ────────────────────────────────────────────────
WEBAUTHN_RP_ID=localhost
WEBAUTHN_RP_NAME=Crontech
WEBAUTHN_ORIGIN=http://localhost:3000

# ── Google OAuth ───────────────────────────────────────────────────────
# Create at: https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
# Base URL for OAuth callback construction. Defaults to http://localhost:3001.
API_BASE_URL=http://localhost:3001
# Where the OAuth flow redirects after success. Defaults to http://localhost:3000.
WEB_APP_URL=http://localhost:3000

# ── Session Secret ─────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
SESSION_SECRET=generate-a-64-char-hex-string

# ── Neon Serverless PostgreSQL ─────────────────────────────────────────
NEON_DATABASE_URL=postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/dbname
NEON_API_KEY=your-neon-api-key

# ── Qdrant Vector Database ─────────────────────────────────────────────
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=your-qdrant-api-key

# ── OpenTelemetry ──────────────────────────────────────────────────────
# When set, the API ships traces/metrics to this OTLP endpoint.
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# ── Stripe ─────────────────────────────────────────────────────────────
# Master kill-switch for all billing procedures that CREATE payments
# (checkout session, portal session, subscription start, payment intent).
#
# Behaviour matrix:
#   STRIPE_ENABLED=true            → full checkout + portal live.
#   STRIPE_ENABLED=false (or unset)→ billing.createCheckoutSession and
#                                     billing.createPortalSession return a
#                                     clean SERVICE_UNAVAILABLE error. The
#                                     /billing route detects this via the
#                                     public billing.getStatus probe and
#                                     renders the PreLaunchBilling
#                                     waitlist surface instead of an error
#                                     bubble. Read-only procedures
#                                     (getPlans, getSubscription,
#                                     getStatus, joinWaitlist) stay open.
#
# Default (unset) is the SAFE pre-launch posture. Flip to "true" ONLY
# when billing goes live post-launch and the Worker is redeployed so the
# new env value is picked up.
#
# Webhook handlers ignore this flag — they must still parse any late-
# firing Stripe webhook defensively, independent of the UI state.
STRIPE_ENABLED=false
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key
STRIPE_WEBHOOK_SECRET=whsec_your-stripe-webhook-secret

# ── Sentinel (Optional) ────────────────────────────────────────────────
GITHUB_TOKEN=ghp_your-github-token
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/your/webhook/url
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your/webhook/url
# Port the Sentinel intel service listens on. Defaults to 3002.
SENTINEL_PORT=3002

# ── Orchestrator (project deployer) ────────────────────────────────────
# Port the tenant/project orchestrator listens on. Defaults to 9000.
ORCHESTRATOR_PORT=9000
# URL the API uses to reach the orchestrator. Defaults to http://127.0.0.1:9000.
ORCHESTRATOR_URL=http://127.0.0.1:9000
# Caddy admin API for reverse-proxy config. Defaults to http://localhost:2019.
CADDY_ADMIN_URL=http://localhost:2019

# ── Gluecron Push-Notification Receiver ────────────────────────────────
# Shared secret for the inbound POST /api/hooks/gluecron/push endpoint.
# Gluecron.com sends `Authorization: Bearer ${GLUECRON_WEBHOOK_SECRET}` on
# every push notification; the endpoint verifies with a timing-safe compare.
# Generate with: openssl rand -hex 32
GLUECRON_WEBHOOK_SECRET=

# ── Gluecron Event Emitter (deploy.succeeded / deploy.failed) ──────────
# Base URL for the Gluecron event bus. Crontech POSTs deploy outcome events
# to `${GLUECRON_EVENT_URL}/api/events/deploy`. Defaults to the public
# Gluecron endpoint; point this at a local/staging instance for development.
GLUECRON_EVENT_URL=https://gluecron.com
# Bearer token Crontech sends to Gluecron on every deploy-event POST. Must
# match the value Gluecron is configured to accept. Missing value = emitter
# short-circuits to a no-op (best-effort; never breaks the deploy itself).
CRONTECH_EVENT_TOKEN=

# ── Email (Resend, primary) ────────────────────────────────────────────
RESEND_API_KEY=re_your-resend-api-key
EMAIL_FROM=noreply@crontech.ai

# ── Email (AlecRae, optional transactional provider) ───────────────────
# When both are set, AlecRae takes priority over Resend.
ALECRAE_API_URL=
ALECRAE_API_KEY=

# ── Inbound email (Resend) ─────────────────────────────────────────────
RESEND_INBOUND_SECRET=your-resend-webhook-signing-secret
SUPPORT_EMAIL=support@crontech.ai
SUPPORT_AUTO_SEND_THRESHOLD=85

# ── Branding & Public URLs ─────────────────────────────────────────────
# Set these once you have a domain. Everything updates automatically.
SITE_NAME=Crontech
PUBLIC_URL=https://crontech.ai

# ── Public API URL (server-side) ───────────────────────────────────────
PUBLIC_API_URL=https://api.crontech.ai

# ── Vite (browser-exposed env vars - must be prefixed VITE_) ───────────
VITE_PUBLIC_URL=https://crontech.ai
VITE_SITE_NAME=Crontech
VITE_API_URL=https://api.crontech.ai
# tRPC client reads this first; falls back to VITE_API_URL.
VITE_PUBLIC_API_URL=https://api.crontech.ai

# ── Cloudflare R2 (File Storage) ───────────────────────────────────────
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=crontech-assets
MAX_UPLOAD_SIZE_MB=50

# ── Upstash Redis (Background Job Queue) ───────────────────────────────
UPSTASH_REDIS_URL=redis://your-upstash-redis-endpoint:6379
UPSTASH_REDIS_TOKEN=your-upstash-redis-token
# For local dev (optional, overrides Upstash when set):
# REDIS_URL=redis://localhost:6379
