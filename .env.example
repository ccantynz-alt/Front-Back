# ═══════════════════════════════════════════════════════════════════════
# Back to the Future — Environment Variables
# ═══════════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values.
#   cp .env.example .env
#
# Variables marked [REQUIRED] must be set for the service to function.
# Variables marked [OPTIONAL] have sensible defaults or are only needed
# for specific features.
# ═══════════════════════════════════════════════════════════════════════

# ── API Server ───────────────────────────────────────────────────────
# [OPTIONAL] Port the Hono API server listens on (default: 3001)
API_PORT=3001

# [OPTIONAL] Node environment (development | production | test)
NODE_ENV=development

# [OPTIONAL] Public API URL accessible from the browser
PUBLIC_API_URL=http://localhost:3001

# ── Database — Turso (Primary Edge SQLite) ───────────────────────────
# [REQUIRED] Turso/libSQL database URL
DATABASE_URL=libsql://your-database.turso.io

# [OPTIONAL] Turso auth token (required for remote databases, not for local file:local.db)
DATABASE_AUTH_TOKEN=your-turso-auth-token

# ── Database — Neon (Serverless PostgreSQL) ──────────────────────────
# [REQUIRED for Neon features] Neon serverless PostgreSQL connection string
NEON_DATABASE_URL=postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/dbname?sslmode=require

# ── Vector Database — Qdrant ─────────────────────────────────────────
# [OPTIONAL] Qdrant server URL (default: http://localhost:6333)
QDRANT_URL=http://localhost:6333

# [OPTIONAL] Qdrant API key (required for Qdrant Cloud, not needed for local)
QDRANT_API_KEY=your-qdrant-api-key

# ── AI — Cloud Provider ─────────────────────────────────────────────
# [REQUIRED for AI features] OpenAI API key (primary provider for cloud + edge tiers)
OPENAI_API_KEY=sk-your-openai-api-key

# [OPTIONAL] OpenAI base URL override (for proxies or API-compatible providers)
OPENAI_BASE_URL=

# [OPTIONAL] OpenAI organization ID
OPENAI_ORG_ID=

# [OPTIONAL] Override default cloud-tier model (default: gpt-4o)
AI_CLOUD_MODEL=gpt-4o

# ── AI — Edge Provider ──────────────────────────────────────────────
# [OPTIONAL] Separate API key for edge-tier inference (falls back to OPENAI_API_KEY)
AI_EDGE_API_KEY=

# [OPTIONAL] Separate base URL for edge-tier inference
AI_EDGE_BASE_URL=

# [OPTIONAL] Override default edge-tier model (default: gpt-4o-mini)
AI_EDGE_MODEL=gpt-4o-mini

# ── AI — Fallback Provider ──────────────────────────────────────────
# [OPTIONAL] API key for a fallback AI provider when primary is unavailable
AI_FALLBACK_API_KEY=

# [OPTIONAL] Base URL for the fallback provider
AI_FALLBACK_BASE_URL=

# [OPTIONAL] Model name for the fallback provider (default: gpt-4o-mini)
AI_FALLBACK_MODEL=gpt-4o-mini

# ── Authentication — WebAuthn / Passkeys ─────────────────────────────
# [OPTIONAL] Relying Party ID for WebAuthn (default: localhost)
WEBAUTHN_RP_ID=localhost

# [OPTIONAL] Relying Party display name
WEBAUTHN_RP_NAME=Back to the Future

# [OPTIONAL] Relying Party origin for WebAuthn (default: http://<RP_ID>:3000)
WEBAUTHN_ORIGIN=http://localhost:3000

# ── Cloudflare — Deployment ──────────────────────────────────────────
# [REQUIRED for deploy] Cloudflare API token with Pages/Workers permissions
CLOUDFLARE_API_TOKEN=your-cloudflare-api-token

# [REQUIRED for deploy] Cloudflare account ID
CLOUDFLARE_ACCOUNT_ID=your-cloudflare-account-id

# ── Payments — Stripe ────────────────────────────────────────────────
# [REQUIRED for payments] Stripe secret key (starts with sk_test_ or sk_live_)
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key

# [REQUIRED for payments] Stripe publishable key (starts with pk_test_ or pk_live_)
STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key

# [REQUIRED for webhooks] Stripe webhook signing secret (starts with whsec_)
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# ── Observability — OpenTelemetry ────────────────────────────────────
# [OPTIONAL] OTLP exporter endpoint for traces, metrics, and logs
# Telemetry is disabled when this is unset.
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# ── Sentinel — Competitive Intelligence ──────────────────────────────
# [OPTIONAL] GitHub personal access token for repository monitoring
GITHUB_TOKEN=ghp_your-github-token

# [OPTIONAL] Slack incoming webhook URL for Sentinel alerts
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T00/B00/xxxx

# [OPTIONAL] Anthropic API key (alternative AI provider for Sentinel analysis)
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key
