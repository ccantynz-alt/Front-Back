{
  "name": "back-to-the-future",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*",
    "services/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "test": "turbo test",
    "lint": "turbo lint",
    "format": "turbo format",
    "check": "turbo check",
    "clean": "turbo clean",
    "sentinel:once": "cd services/sentinel && bun run src/run-once.ts",
    "check-links": "bun run scripts/link-checker.ts",
    "check-buttons": "bun run scripts/button-checker.ts",
    "check-bundle": "bun run scripts/bundle-size-check.ts",
    "check-a11y": "bun run scripts/a11y-check.ts",
    "generate-sitemap": "bun run scripts/generate-sitemap.ts",
    "prebuild": "bun run scripts/generate-sitemap.ts",
    "test:e2e": "playwright test"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.0",
    "@resvg/resvg-js": "2.6.2",
    "turbo": "^2"
  },
  "packageManager": "bun@1.3.9"
}
