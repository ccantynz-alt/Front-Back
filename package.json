{
  "name": "crontech",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*",
    "services/*"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "test": "turbo test",
    "lint": "turbo lint",
    "format": "turbo format",
    "check": "turbo check",
    "clean": "turbo clean",
    "sentinel:once": "cd services/sentinel && bun run src/run-once.ts",
    "check-links": "bun run scripts/link-checker.ts",
    "smoke": "bun run scripts/smoke-test.ts",
    "check-buttons": "bun run scripts/button-checker.ts",
    "check-bundle": "bun run scripts/bundle-size-check.ts",
    "check-a11y": "bun run scripts/a11y-check.ts",
    "generate-sitemap": "bun run scripts/generate-sitemap.ts",
    "prebuild": "bun run scripts/generate-sitemap.ts",
    "test:e2e": "gatetest --crawl http://localhost:3000 --module visual --module accessibility --module links",
    "db:status": "bun run scripts/db-status.ts",
    "db:validate": "bun run scripts/db-validate.ts"
  },
  "devDependencies": {
    "@resvg/resvg-js": "2.6.2",
    "turbo": "^2"
  },
  "packageManager": "bun@1.3.9"
}
