{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "dev": {
      "cache": false,
      "persistent": true
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".output/**", ".vinxi/**"]
    },
    "test": {
      "dependsOn": ["build"]
    },
    "lint": {},
    "format": {},
    "check": {
      "dependsOn": ["^build"]
    },
    "clean": {
      "cache": false
    },
    "check-bundle": {
      "dependsOn": ["build"],
      "cache": false
    },
    "check-a11y": {
      "cache": false
    }
  }
}
