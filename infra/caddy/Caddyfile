# Crontech — production Caddyfile
# Place at /etc/caddy/Caddyfile on the Vultr server.
# Caddy auto-provisions TLS via Let's Encrypt.

crontech.ai, www.crontech.ai {
    # API routes go to the Hono backend
    handle /api/* {
        reverse_proxy localhost:3001
    }

    # WebSocket upgrade for live logs + real-time
    handle /ws/* {
        reverse_proxy localhost:3001 {
            header_up Upgrade {http.request.header.Upgrade}
            header_up Connection {http.request.header.Connection}
        }
    }

    # Everything else goes to the SolidStart SSR server
    handle {
        reverse_proxy localhost:3000
    }

    # Security headers
    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains"
        X-Content-Type-Options nosniff
        X-Frame-Options DENY
        Referrer-Policy strict-origin-when-cross-origin
        -Server
    }

    encode gzip
    log {
        output file /var/log/caddy/crontech.log
    }
}
