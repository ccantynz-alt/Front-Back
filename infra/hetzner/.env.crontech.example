# Crontech Platform — Environment Variables (Phase 1)
# Copy to .env and fill in your values:
#   cp .env.crontech.example .env

# ── Domain ──────────────────────────────────────────────
CRONTECH_DOMAIN=crontech.ai

# ── Database ────────────────────────────────────────────
# Local PostgreSQL (from docker-compose)
DATABASE_URL=postgresql://crontech:CHANGE_ME_STRONG_PASSWORD@postgres:5432/crontech
POSTGRES_USER=crontech
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ── Auth Secrets (generate with: openssl rand -hex 32) ──
SESSION_SECRET=CHANGE_ME
JWT_SECRET=CHANGE_ME

# ── Stripe (https://dashboard.stripe.com/apikeys) ──────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ── AI (optional — features degrade gracefully) ────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ── Email ───────────────────────────────────────────────
# AlecRae MTA (primary — your own infrastructure)
ALECRAE_API_URL=
ALECRAE_API_KEY=
# Resend (fallback — until AlecRae MTA is live)
RESEND_API_KEY=

# ── Qdrant (optional — vector search degrades gracefully)
QDRANT_API_KEY=

# ── Observability (optional) ───────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=
