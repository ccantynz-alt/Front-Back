# crontech-watchdog.timer — fires the watchdog every 2 minutes
#
# Enable with:
#   systemctl enable --now crontech-watchdog.timer
[Unit]
Description=Crontech Watchdog Timer (every 2 minutes)
Requires=crontech-watchdog.service

[Timer]
OnBootSec=30sec
OnUnitActiveSec=2min
AccuracySec=10sec

[Install]
WantedBy=timers.target
